DATABASE_URL=postgresql+asyncpg://farewise:farewise@localhost:5432/farewise
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com
ANTHROPIC_API_KEY=your_anthropic_api_key
CORS_ORIGINS=http://localhost:5173

# Flight data provider: "db1b" (synthetic historical), "amadeus", "composite",
# or "flightapi" (live fares). Live fares are per-tenant rate-limited — see
# FLIGHTAPI_* settings below.
FLIGHT_DATA_PROVIDER=db1b

# FlightAPI.io — only required when FLIGHT_DATA_PROVIDER=flightapi.
# Treat the key like a secret; never commit the populated .env.
# Lite plan defaults: 30,000 credits/month, 5 concurrent requests.
FLIGHTAPI_API_KEY=
FLIGHTAPI_BASE_URL=https://api.flightapi.io
FLIGHTAPI_CONCURRENCY_LIMIT=5
FLIGHTAPI_DEFAULT_CREDIT_BUDGET=30000
FLIGHTAPI_CREDITS_PER_SEARCH=1
FLIGHTAPI_REQUEST_TIMEOUT=20
